<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/skillsaint/db" VERSION="20240410" COMMENT="XMLDB file for local_skillsaint"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_skillsaint_apps" COMMENT="Store student applications before and after payment">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Unique identifier for the application"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Moodle user ID if already logged in"/>
        <FIELD NAME="fullname" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="User full name"/>
        <FIELD NAME="email" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="User email address"/>
        <FIELD NAME="phone" TYPE="char" LENGTH="50" NOTNULL="false" COMMENT="User phone number"/>
        <FIELD NAME="address" TYPE="text" NOTNULL="false" COMMENT="User physical address"/>
        <FIELD NAME="motivation" TYPE="text" NOTNULL="false" COMMENT="User motivation for application"/>
        <FIELD NAME="spiritual_bg" TYPE="text" NOTNULL="false" COMMENT="Combined spiritual info"/>
        <FIELD NAME="selected_plan" TYPE="char" LENGTH="50" NOTNULL="true" COMMENT="Selected membership or course plan"/>
        <FIELD NAME="selected_courses" TYPE="text" NOTNULL="false" COMMENT="JSON or comma-separated list of courses"/>
        <FIELD NAME="payment_status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" COMMENT="Status of payment (pending, paid, etc)"/>
        <FIELD NAME="activation_code" TYPE="char" LENGTH="20" NOTNULL="false" COMMENT="Code to activate the account"/>
        <FIELD NAME="is_activated" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="Flag for activation status"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Timestamp of creation"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Timestamp of last modification"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id" COMMENT="Primary key for the table"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="email_idx" UNIQUE="false" FIELDS="email" COMMENT="Search index for user email"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_skillsaint_inquiries" COMMENT="Student support inquiries linked to courses">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Moodle user ID of the student"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="The course this inquiry is about"/>
        <FIELD NAME="subject" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="Short subject/title"/>
        <FIELD NAME="message" TYPE="text" NOTNULL="true" COMMENT="Student message content"/>
        <FIELD NAME="admin_reply" TYPE="text" NOTNULL="false" COMMENT="Admin reply to the student"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="open" COMMENT="open, replied, or resolved"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_skillsaint_messages" COMMENT="Individual messages within an inquiry thread">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="inquiry_id" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Link to local_skillsaint_inquiries"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Sender user ID"/>
        <FIELD NAME="message" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_skillsaint_exam_results" COMMENT="Track user exam attempts and scores">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="quizid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="score" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0.00"/>
        <FIELD NAME="correct_count" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="total_questions" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="attempt_number" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="user_quiz_idx" UNIQUE="false" FIELDS="userid, quizid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
